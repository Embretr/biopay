{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "outDir": "dist",
    "composite": false,
    "noEmit": true
  },
  "include": ["src", "../../packages/auth/src", "../../packages/db/src"]
}
