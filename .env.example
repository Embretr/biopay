# ─────────────────────────────────────────────────────────────────────────────
# BioPay Environment Variables
# Copy this file to .env and fill in the values.
#
# MOCK MODE: The system runs in full mock mode when the external service
# credentials (BANKID_*, PALMID_*, MANGOPAY_*) are absent or empty.
# You only need DATABASE_URL + REDIS_URL + JWT secrets to run locally.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for all modes ────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/biopay"
REDIS_URL="redis://localhost:6379"

# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-generate-with-openssl-rand-hex-32"
JWT_REFRESH_SECRET="change-me-another-secret-please-generate"

# ── API server ─────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS="http://localhost:3000,exp://localhost:8081"

# ── Web app ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_ENV="development"

# ── BankID via Idura (omit = mock mode) ──────────────────────────────────────
# Get test credentials free at https://idura.eu
# BANKID_CLIENT_ID=""
# BANKID_CLIENT_SECRET=""
# BANKID_ISSUER="https://auth.bankid.no/auth/realms/prod"
# BANKID_REDIRECT_URI="http://localhost:3001/auth/bankid/callback"

# ── PalmID SaaS (omit = mock mode) ───────────────────────────────────────────
# Requires commercial agreement with PalmID / Redrock Biometrics
# PALMID_API_KEY=""
# PALMID_API_BASE_URL="https://api.palmid.com"
# PALMID_WEBHOOK_SECRET="change-me-to-hmac-secret-from-palmid"

# ── Mangopay (omit = mock mode) ───────────────────────────────────────────────
# Register at https://mangopay.com — sandbox available immediately
# MANGOPAY_CLIENT_ID=""
# MANGOPAY_API_KEY=""
# MANGOPAY_BASE_URL="https://api.sandbox.mangopay.com"
# MANGOPAY_PLATFORM_WALLET_ID=""

# ── Expo Push Notifications (optional) ───────────────────────────────────────
# Expo push works without a token in development (Expo handles it)
# EXPO_ACCESS_TOKEN=""
